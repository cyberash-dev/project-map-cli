{
  "name": "project-map-cli",
  "version": "0.1.1",
  "description": "CLI that builds a deterministic PROJECT_MAP.md architectural map for a single repository (Python, JS/TS, Go, Java, Kotlin)",
  "license": "MIT",
  "author": "cyberash",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "project-map": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "project-map",
    "architecture",
    "tree-sitter",
    "cli",
    "hexagonal",
    "vertical-slice"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyberash-dev/project-map-cli.git"
  },
  "bugs": {
    "url": "https://github.com/cyberash-dev/project-map-cli/issues"
  },
  "homepage": "https://github.com/cyberash-dev/project-map-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run lint && npm run build && npm test",
    "start": "node dist/cli/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "14.0.0",
    "cosmiconfig": "9.0.0",
    "globby": "14.1.0",
    "mdast-util-gfm-table": "2.0.0",
    "mdast-util-to-markdown": "2.1.2",
    "p-limit": "6.2.0",
    "picocolors": "1.1.1",
    "tree-sitter": "0.22.4",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.23.1",
    "@tree-sitter-grammars/tree-sitter-kotlin": "1.1.0",
    "tree-sitter-python": "0.23.6",
    "tree-sitter-typescript": "0.23.2",
    "yaml": "2.8.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/mdast": "4.0.4",
    "@types/node": "25.0.10",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "overrides": {
    "tree-sitter-go": {
      "tree-sitter": "$tree-sitter"
    },
    "tree-sitter-java": {
      "tree-sitter": "$tree-sitter"
    },
    "tree-sitter-javascript": {
      "tree-sitter": "$tree-sitter"
    },
    "tree-sitter-typescript": {
      "tree-sitter": "$tree-sitter"
    }
  }
}
